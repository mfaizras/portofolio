---
import { type CollectionEntry, getCollection } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";
import FloatingNavbar from "../../components/FloatingNavbar";
import { Image } from "astro:assets";
import { Calendar, Clock, ArrowLeft } from "lucide-react";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}
type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content } = await post.render();

const heroImage =
  typeof post.data.heroImage === "object"
    ? post.data.heroImage.src
    : post.data.heroImage || "/blog-placeholder.png";
---

<BlogLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  image={heroImage}
  type="article"
>
  <FloatingNavbar client:load />
  <!-- Progress Bar -->
  <div class="fixed top-0 left-0 w-full h-1 z-50 bg-bgSecondary">
    <div class="h-full bg-primary origin-left scale-x-0" id="progress-bar">
    </div>
  </div>

  <article class="bg-bg min-h-screen pt-24 pb-20">
    <div class="max-w-4xl mx-auto px-4">
      {/* Back Button */}
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-secondary hover:text-primary transition-colors mb-8 group pl-2"
      >
        <ArrowLeft
          size={20}
          class="group-hover:-translate-x-1 transition-transform"
        />
        Back to Blog
      </a>

      {/* Hero Section */}
      <div class="mb-12">
        <div
          class="flex items-center gap-6 text-sm text-secondary font-mono mb-6"
        >
          <span class="flex items-center gap-2">
            <Calendar size={16} />
            {
              post.data.pubDate.toLocaleDateString("en-us", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })
            }
          </span>

          {
            post.data.updatedDate && (
              <div class="italic">
                Last updated on{" "}
                {post.data.updatedDate.toLocaleDateString("en-us", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </div>
            )
          }
        </div>

        <h1
          class="text-3xl md:text-5xl lg:text-6xl font-bold text-heading mb-8 leading-tight"
        >
          {post.data.title}
        </h1>

        <div class="flex gap-3 flex-wrap mb-10">
          {
            post.data.tags?.map((tag) => (
              <span class="px-3 py-1 text-xs uppercase tracking-wider font-bold bg-primary/10 text-primary rounded-full border border-primary/20">
                {tag}
              </span>
            ))
          }
        </div>

        {
          post.data.heroImage && (
            <div class="rounded-2xl overflow-hidden shadow-2xl border border-white/5 aspect-video relative">
              <Image
                src={post.data.heroImage}
                alt={post.data.title}
                width={1200}
                height={600}
                class="w-full h-full object-cover"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-bg via-transparent to-transparent opacity-20" />
            </div>
          )
        }
      </div>

      {/* Content */}
      <div
        class="prose prose-invert prose-lg max-w-none prose-headings:text-heading prose-a:text-primary prose-a:no-underline hover:prose-a:underline prose-img:rounded-xl prose-pre:bg-bgSecondary prose-pre:border prose-pre:border-white/10 text-justify"
      >
        <Content />
      </div>
    </div>
  </article>

  <script>
    // Reading Progress Bar
    const progressBar = document.getElementById("progress-bar");
    window.addEventListener("scroll", () => {
      if (progressBar) {
        const winScroll =
          document.body.scrollTop || document.documentElement.scrollTop;
        const height =
          document.documentElement.scrollHeight -
          document.documentElement.clientHeight;
        const scrolled = (winScroll / height) * 100;
        progressBar.style.transform = `scaleX(${scrolled / 100})`;
      }
    });
  </script>
</BlogLayout>
