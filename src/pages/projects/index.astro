---
import BlogLayout from "../../layouts/BlogLayout.astro";
import { ArrowLeft } from "lucide-react";
import FloatingNavbar from "../../components/FloatingNavbar";
import ProjectsGrid from "../../components/ProjectsGrid";
import { getCollection } from "astro:content";

const projectEntries = (await getCollection("projects")).sort((a, b) => {
  const orderA = a.data.order ?? Number.POSITIVE_INFINITY;
  const orderB = b.data.order ?? Number.POSITIVE_INFINITY;
  const featuredA = a.data.featured ?? false;
  const featuredB = b.data.featured ?? false;

  if (featuredA !== featuredB) {
    return featuredA ? -1 : 1;
  }

  if (orderA !== orderB) {
    return orderA - orderB;
  }

  return a.data.title.localeCompare(b.data.title);
});

const projectItems = projectEntries.map((entry, index) => ({
  id: index + 1,
  title: entry.data.title,
  summary: entry.data.description,
  description: entry.data.description,
  techStack: entry.data.techStack,
  links: {
    demo: entry.data.demo,
    github: entry.data.github,
    blog: entry.data.blog,
  },
  image: entry.data.heroImage,
  categories: entry.data.categories,
  featured: entry.data.featured,
  order: entry.data.order,
  stars: entry.data.stars ?? null,
  slug: entry.slug,
}));

const galleryImages = projectEntries
  .filter((entry) => Boolean(entry.data.heroImage))
  .map((entry) => ({
    title: entry.data.title,
    image: entry.data.heroImage,
  }));
---

<BlogLayout
  title="Projects | Faiz Rashid"
  description="A focused selection of web apps, APIs, and AI systems I have built."
>
  <FloatingNavbar client:load />
  <main class="min-h-screen bg-bg relative overflow-hidden pt-32 pb-20 px-4 sm:px-6 lg:px-10 xl:px-16">
    <div class="max-w-6xl mx-auto z-10 relative">
      <div class="mb-8">
        <a
          href="/"
          class="inline-flex items-center gap-2 text-secondary hover:text-primary transition-colors group"
        >
          <ArrowLeft
            size={20}
            className="group-hover:-translate-x-1 transition-transform"
          />
          Back to Home
        </a>
      </div>

      <header class="mb-12 text-center">
        <h1 class="text-4xl md:text-6xl font-bold text-heading mb-6">
          Projects
        </h1>
        <p class="text-text text-lg max-w-2xl mx-auto">
          A curated list of products, platforms, and experiments across web, API,
          and AI domains.
        </p>
      </header>

      <ProjectsGrid
        client:load
        showViewAll={false}
        items={projectItems}
      />
    </div>
  </main>
</BlogLayout>
