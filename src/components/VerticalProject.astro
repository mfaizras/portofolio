---
import ProjectsGrid from "./ProjectsGrid.tsx";
import { getCollection } from "astro:content";

const projectEntries = (await getCollection("projects"))
  .sort((a, b) => {
    const orderA = a.data.order ?? Number.POSITIVE_INFINITY;
    const orderB = b.data.order ?? Number.POSITIVE_INFINITY;
    const featuredA = a.data.featured ?? false;
    const featuredB = b.data.featured ?? false;

    if (featuredA !== featuredB) {
      return featuredA ? -1 : 1;
    }

    if (orderA !== orderB) {
      return orderA - orderB;
    }

    return a.data.title.localeCompare(b.data.title);
  })
  .slice(0, 6);
const projectItems = projectEntries.map((entry, index) => ({
  id: index + 1,
  title: entry.data.title,
  summary: entry.data.description,
  description: entry.data.description,
  techStack: entry.data.techStack,
  links: {
    demo: entry.data.demo,
    github: entry.data.github,
    blog: entry.data.blog,
  },
  image:
    typeof entry.data.heroImage === "object"
      ? entry.data.heroImage.src
      : entry.data.heroImage,
  categories: entry.data.categories,
  featured: entry.data.featured,
  order: entry.data.order,
  stars: entry.data.stars ?? null,
  slug: entry.slug,
}));
---

<section id="projects" class="py-12 md:py-24 bg-bg">
  <div class="max-w-7xl mx-auto px-4 mb-8">
    <h2 class="text-3xl md:text-5xl font-bold text-center text-heading mb-4">
      Projects
    </h2>
    <p class="text-center text-text max-w-2xl mx-auto">
      Explore some of the technical challenges I've solved and the applications
      I've built.
    </p>
  </div>

  <div class="max-w-7xl mx-auto px-4">
    <ProjectsGrid client:visible items={projectItems} />
  </div>
</section>
